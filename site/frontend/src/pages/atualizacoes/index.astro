---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Atualizações do Sistema">
  <div class="container em-breve">
    <div class="icon">⚡</div>
    <h1>Atualizações do Sistema</h1>
    <p>Atualizações internas da plataforma Frota 162, direto dos canais do Slack.<br/>Em desenvolvimento — em breve por aqui.</p>
  </div>
</BaseLayout>

<style>
  .em-breve {
    text-align: center;
    padding: 6rem 0;
  }

  .icon {
    font-size: 4rem;
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  p {
    color: var(--texto-suave);
    font-size: 1.1rem;
    line-height: 1.7;
  }
</style>
