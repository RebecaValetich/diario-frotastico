---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Startups / VC">
  <div class="container em-breve">
    <div class="icon">💸</div>
    <h1>Startups / VC</h1>
    <p>Captações, fusões e novos players no ecossistema de mobilidade e logística.<br/>Em desenvolvimento — em breve por aqui.</p>
  </div>
</BaseLayout>

<style>
  .em-breve {
    text-align: center;
    padding: 6rem 0;
  }

  .icon {
    font-size: 4rem;
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  p {
    color: var(--texto-suave);
    font-size: 1.1rem;
    line-height: 1.7;
  }
</style>
