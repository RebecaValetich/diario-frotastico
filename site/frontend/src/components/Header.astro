---
const { pathname } = Astro.url;
const isActive = (path: string) => pathname === path || pathname.startsWith(path + '/');
---

<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <span class="logo-emoji">🚛</span>
      <span class="logo-text">Atualizações<br/><strong>Frotásticas</strong></span>
    </a>

    <nav class="nav">
      <a href="/" class:list={["nav-link", { active: pathname === '/' }]}>Home</a>
      <a href="/orgaos-publicos" class:list={["nav-link", { active: isActive('/orgaos-publicos') }]}>Órgãos Públicos</a>
      <a href="/mercado" class:list={["nav-link", { active: isActive('/mercado') }]}>Mercado</a>
      <a href="/startups-vc" class:list={["nav-link", { active: isActive('/startups-vc') }]}>
        Startups/VC
        <span class="badge">Em breve</span>
      </a>
      <a href="/atualizacoes" class:list={["nav-link", { active: isActive('/atualizacoes') }]}>
        Atualizações do Sistema
        <span class="badge">Em breve</span>
      </a>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: white;
    border-bottom: 2px solid var(--laranja);
    padding: 1rem 0;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: var(--texto);
  }

  .logo-emoji {
    font-size: 2rem;
  }

  .logo-text {
    font-family: var(--fonte-titulo);
    font-size: 0.9rem;
    line-height: 1.3;
    color: var(--texto-suave);
  }

  .logo-text strong {
    font-size: 1.1rem;
    color: var(--laranja);
    display: block;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-wrap: wrap;
  }

  .nav-link {
    font-family: var(--fonte-corpo);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--texto-suave);
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .nav-link:hover {
    color: var(--laranja);
    background: var(--laranja-claro);
  }

  .nav-link.active {
    color: var(--laranja);
    background: var(--laranja-claro);
    font-weight: 600;
  }

  .badge {
    font-size: 0.65rem;
    background: var(--cinza-medio);
    color: var(--texto-suave);
    padding: 0.1rem 0.4rem;
    border-radius: 999px;
    font-weight: 400;
  }
</style>
